# ============================================================
# CodeDoc Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Required: Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_GENAI_USE_VERTEXAI=true
# Vertex AI location (Gemini + embeddings)
GOOGLE_CLOUD_LOCATION=global

# --- Gemini ---
GEMINI_MODEL=gemini-3.5-flash
GEMINI_CONCURRENCY=100
# Output token cap per request; Gemini-3 thinking shares this budget,
# so too low yields empty responses — keep it generous
MAX_OUTPUT_TOKENS=8192

# --- Spanner Graph ---
SPANNER_INSTANCE=codedoc-instance
SPANNER_DATABASE=codedoc-db
# GRAPH_NAME + ID_PREFIX allow side-by-side graphs in one database
GRAPH_NAME=code_graph_a
ID_PREFIX=a

# --- Output ---
OUTPUT_DIR=output_docs_pipeline
EMBED_CONCURRENCY=20

# --- LSP resolution (Phase 1.6) ---
# Intelephense binary (npm i -g intelephense); if missing, Phase 1.6
# degrades to convention/parser-only resolution with a loud warning
INTELEPHENSE_PATH=intelephense
# Timeouts in seconds: initial workspace indexing / each definition request
LSP_INDEX_TIMEOUT=300
LSP_REQUEST_TIMEOUT=15
# Unresolved/ambiguous calls become PossiblyCalls edges only when the
# same-named candidate count stays at or below this cap
POSSIBLY_CALLS_MAX_CANDIDATES=5

# --- Vendor scanning ---
# Empty = ask interactively when vendor PHP files are found (non-TTY
# defaults to exclude); set true/false to skip the prompt
INCLUDE_VENDOR=

# Fix SSL mTLS on GCE
GCE_METADATA_MTLS_MODE=none
